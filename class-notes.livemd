## keyword lists

```elixir
{:one, 1}
```

```elixir
[{:one, 1}, {:two, 2}]
```

```elixir
{:module, :function, arg1: :arg}
```

```elixir
{:vancouver, :ca, planet: :world, not: :usa}
```

```elixir
defmodule Greeter do
  def say(phrase), do: IO.puts(phrase)
end
```

```elixir
defmodule Greeter2 do
  def say(phrase) do
     IO.puts(phrase)
  end
end
```

```elixir
defmodule Greeter3 do
  def(say(phrase), do: IO.puts(phrase))
end
```

```elixir
defmodule Greeter4 do
  def(say(phrase), [do: IO.puts(phrase)])
end
```

```elixir
defmodule Greeter5 do
  def(say(phrase), [{:do, IO.puts(phrase)}])
end
```

```elixir
x = 4
if x == 4 do
  :something
else
  :something_else
end

if x == 4, do: :something, else: :something_else
```

```elixir
exports(Kernel)
```

## for comprehensions

generators, filters, mapper (inside do), into for different types, and more

```elixir
for x <- ?a..?z, y <- ~w[one two three], x < ?f, x > ?c, into: MapSet.new(), do: {x, y}

```

```elixir
h for
```

## Pattern Matching

```elixir
x = 2
x = 3

```

```elixir
place = {:vancouver, :ca}
```

```elixir
{city, country} = place
```

```elixir
map = %{name: "jeff", age: 33, job: :being_awesome}
```

```elixir
%{} = map
```

```elixir
%{name: name} = map
```

```elixir
name
```

```elixir
%{name: name} = map
```

```elixir
provence = "ontario"
```

```elixir
"on" <> rest = provence
```

```elixir
rest
```

```elixir
list = [:orange, :apple, :pear]
```

```elixir
[head | tail] = list
```

```elixir
tail
```

```elixir
defmodule MyEnum do
  def count([]), do: 0
  def count([_head | rest]), do: 1 + count(rest)
end
```

```elixir
MyEnum.count(list)
```

```elixir
[:banana | tail]
```

```elixir
[:guava | tail]
```

```elixir
list |> Enum.map(&to_string/1) |> Enum.join("") |> IO.puts()
```

```elixir
list |> Enum.map(&to_string/1) |> IO.puts()
```

```elixir
for f <- list, into: %{}, do: {f, 0}
```

```elixir
list2 = list
```

```elixir
list3 = [:orange, :apple, :mango]
```

```elixir
^list3 = list
```

```elixir
value = "hello"
sentence = [value]
```

```elixir
value = [value, " Who's there? "]
```

```elixir
value = ["Hi " | value]
```

```elixir
[value, " Kyle"]
```

```elixir
IO.puts sentence
